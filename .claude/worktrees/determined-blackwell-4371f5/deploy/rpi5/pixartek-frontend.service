[Unit]
Description=PIXARTEK Frontend (Next.js)
After=network.target
Wants=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/pixartek/frontend/.next/standalone
ExecStart=/usr/bin/node server.js
Restart=always
RestartSec=3
Environment=NODE_ENV=production
Environment=PORT=3000
Environment=NEXT_PUBLIC_API_URL=http://192.168.86.243:8000
Environment=NEXT_PUBLIC_WS_URL=ws://192.168.86.243:8000

[Install]
WantedBy=multi-user.target
