[Unit]
Description=PIXARTEK Vision Node — Servidor de video independiente
After=network.target
Wants=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/pixartek/nodes/vision
ExecStart=/home/pi/pixartek/nodes/vision/.venv/bin/python main.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
